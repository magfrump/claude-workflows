# .shellcheckrc — Project-wide ShellCheck configuration
#
# ShellCheck automatically reads this file from the repo root.
# Only suppress rules that are documented false positives in this project.

# SC1091: "Not following: <file> was not specified as input"
# Suppressed because the self-improvement loop runs shellcheck inside
# temporary git worktrees where sourced files (e.g., test helpers,
# scripts/self-improvement.sh) may not be present at the expected
# relative paths. This causes spurious failures in Gate 1f and was
# the dominant R2 rejection reason (2/2 .sh-touching tasks rejected).
# The -x flag (follow sources) is still useful but cannot resolve
# paths that don't exist in the worktree checkout.
disable=SC1091
